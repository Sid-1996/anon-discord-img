# Discord Webhook URL — required
# Go to your Discord channel → Edit Channel → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# API Access Token — strongly recommended
# Set a custom token to prevent unauthorized access. The frontend sends this in x-access-token header.
ACCESS_TOKEN=choose-a-strong-random-token

# Upstash Redis — optional, for distributed rate limiting
# Only needed if you deploy on multiple Vercel regions
# 1. Go to https://console.upstash.com (or Vercel Marketplace → Upstash Redis)
# 2. Create a new database
# 3. Copy the REST API URL and Token below
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
